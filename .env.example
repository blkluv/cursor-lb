# ── 🔴 Required to run ────────────────────────────────────────────────────────

# Secret for signing session cookies. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-secret

# SQLite database path (default is fine for local dev)
DATABASE_URL=sqlite:///./data/app.db

# ── 🟡 Required for real invoice email (Mailjet) ──────────────────────────────

# Get keys: https://app.mailjet.com/account/apikeys
MAILJET_API_KEY=your-mailjet-api-key
MAILJET_API_SECRET=your-mailjet-api-secret

# Sender must be verified in your Mailjet account
MAILJET_FROM_EMAIL=alizubair6475@gmail.com
MAILJET_FROM_NAME=Matt Photography

# mock = log to logs/email_mock.log (tests default) | mailjet = send via API
EMAIL_MODE=mailjet

# ── Company letterhead (invoice PDF + email) ─────────────────────────────────

COMPANY_NAME=Matt Photography
COMPANY_TAGLINE=Professional photography & visual storytelling
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=alizubair6475@gmail.com
COMPANY_WEBSITE=

# ── Customer portal defaults ─────────────────────────────────────────────────

# Studio owner who receives customer bookings (must match the photographer login email)
PHOTOGRAPHER_EMAIL=matt@studio.com
DEFAULT_SHOOT_AMOUNT_CENTS=250000
DEFAULT_TAX_RATE=0.08
DEFAULT_PAYMENT_DUE_DAYS=14
APP_BASE_URL=http://127.0.0.1:8000

# ── 🟢 Optional ─────────────────────────────────────────────────────────────

HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info
